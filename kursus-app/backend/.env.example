# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kursus_db?schema=public"

# JWT
JWT_SECRET="ganti_dengan_secret_yang_kuat_minimal_32_karakter"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development

# Midtrans (Sandbox) — ambil dari https://dashboard.sandbox.midtrans.com
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxxxxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxxxxxx"
MIDTRANS_IS_PRODUCTION=false

# URL frontend untuk redirect setelah pembayaran
FRONTEND_URL="http://localhost:5173"
